<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Top bar ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="✕ Cancel"
                android:textColor="#212121"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:paddingStart="0dp" />

            <TextView
                android:id="@+id/tv_screen_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="New Card"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#212121" />
        </RelativeLayout>

        <!-- ── AI Generate Button ── -->
        <Button
            android:id="@+id/btn_generate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:text="✨ Auto-Generate with AI"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:background="@drawable/bg_btn_outlined"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— or fill manually —"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp" />

        <!-- ── Subject label ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subject / Category"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <!-- Subject spinner -->
        <Spinner
            android:id="@+id/spinner_category"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_spinner"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- ── Card Type label ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Card Type"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <!-- Card type spinner -->
        <Spinner
            android:id="@+id/spinner_type"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_spinner"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- ── Title ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Card Title *"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input_selector"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="e.g. Newton's First Law"
            android:inputType="textCapSentences"
            android:maxLength="100"
            android:textSize="14sp"
            android:textColor="#212121"
            android:textColorHint="#BDBDBD" />

        <!-- ── Question ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question (Front) *"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_input_selector"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:hint="e.g. What is Newton's First Law?"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="3"
            android:maxLines="6"
            android:maxLength="500"
            android:textSize="14sp"
            android:textColor="#212121"
            android:textColorHint="#BDBDBD"
            android:gravity="top" />

        <TextView
            android:id="@+id/tv_char_count_q"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="0/500"
            android:textSize="11sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="10dp" />

        <!-- ── Answer ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Answer (Back) *"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_input_selector"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:hint="e.g. An object at rest stays at rest..."
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="3"
            android:maxLines="8"
            android:maxLength="1000"
            android:textSize="14sp"
            android:textColor="#212121"
            android:textColorHint="#BDBDBD"
            android:gravity="top" />

        <TextView
            android:id="@+id/tv_char_count_a"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="0/1000"
            android:textSize="11sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="10dp" />

        <!-- ── Tags ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tags (comma separated)"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_tags"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_selector"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="e.g. physics, motion, force"
            android:inputType="text"
            android:textSize="14sp"
            android:textColor="#212121"
            android:textColorHint="#BDBDBD" />

        <!-- ── Priority ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priority"
            android:textSize="13sp"
            android:textColor="#212121"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <RadioButton
                android:id="@+id/rb_priority_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low"
                android:textSize="14sp"
                android:textColor="#212121"
                android:layout_marginEnd="20dp" />

            <RadioButton
                android:id="@+id/rb_priority_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:textSize="14sp"
                android:textColor="#212121"
                android:checked="true"
                android:layout_marginEnd="20dp" />

            <RadioButton
                android:id="@+id/rb_priority_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textSize="14sp"
                android:textColor="#212121" />
        </RadioGroup>

        <!-- ── Difficulty ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Difficulty"
            android:textSize="13sp"
            android:textColor="#212121"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_difficulty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rb_diff_easy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Easy"
                android:textSize="14sp"
                android:textColor="#212121"
                android:layout_marginEnd="20dp" />

            <RadioButton
                android:id="@+id/rb_diff_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:textSize="14sp"
                android:textColor="#212121"
                android:checked="true"
                android:layout_marginEnd="20dp" />

            <RadioButton
                android:id="@+id/rb_diff_hard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hard"
                android:textSize="14sp"
                android:textColor="#212121" />
        </RadioGroup>

        <!-- ── Save Button ── -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="SAVE CARD"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
