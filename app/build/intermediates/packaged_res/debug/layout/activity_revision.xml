<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    android:padding="16dp">

    <!-- ── Top bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Back"
            android:textColor="#212121"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:background="@android:color/transparent"
            android:paddingStart="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Revision"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Skip"
            android:textColor="#3F51B5"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <!-- ── Progress bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:progressTint="#3F51B5"
            android:progressBackgroundTint="#C5CAE9"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tv_progress_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- ── Card counter ── -->
    <TextView
        android:id="@+id/tv_card_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="0 / 0"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="8dp" />

    <!-- ── Score row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <TextView android:id="@+id/tv_hard_count"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="😖 Hard: 0" android:textSize="12sp"
            android:textColor="#C62828" android:layout_marginEnd="12dp"/>
        <TextView android:id="@+id/tv_med_count"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="😐 Med: 0" android:textSize="12sp"
            android:textColor="#E65100" android:layout_marginEnd="12dp"/>
        <TextView android:id="@+id/tv_easy_count"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="😊 Easy: 0" android:textSize="12sp"
            android:textColor="#1B5E20"/>
    </LinearLayout>

    <!-- ── Flash card ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_flashcard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="14dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#3F51B5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_card_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="12sp"
                android:textColor="#9FA8DA"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tv_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Question will appear here"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3" />

            <View
                android:layout_width="50dp"
                android:layout_height="1dp"
                android:background="#7986CB"
                android:layout_marginVertical="18dp" />

            <TextView
                android:id="@+id/tv_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:textColor="#E8EAF6"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone" />

            <!-- Reveal Answer button - white background, indigo text -->
            <Button
                android:id="@+id/btn_reveal"
                android:layout_width="200dp"
                android:layout_height="44dp"
                android:text="Reveal Answer ↓"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/bg_reveal_button"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Rating buttons ── -->
    <LinearLayout
        android:id="@+id/ll_rating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="14dp">

        <Button
            android:id="@+id/btn_hard"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="😖 Hard"
            android:textColor="#C62828"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_btn_hard" />

        <Button
            android:id="@+id/btn_medium"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="😐 Medium"
            android:textColor="#E65100"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/bg_btn_medium" />

        <Button
            android:id="@+id/btn_easy"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="😊 Easy"
            android:textColor="#1B5E20"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:layout_marginStart="5dp"
            android:background="@drawable/bg_btn_easy" />
    </LinearLayout>

    <!-- ── Empty state ── -->
    <LinearLayout
        android:id="@+id/ll_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🎉" android:textSize="52sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No cards due!" android:textSize="20sp" android:textStyle="bold"
            android:textColor="#212121" android:layout_marginTop="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="All caught up. Come back tomorrow." android:textSize="14sp"
            android:textColor="#757575" android:layout_marginTop="8dp" android:gravity="center" />
    </LinearLayout>

    <!-- ── Session complete ── -->
    <LinearLayout
        android:id="@+id/ll_session_complete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🏆" android:textSize="56sp" />

        <TextView
            android:id="@+id/tv_session_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Session Complete!"
            android:textSize="16sp"
            android:textColor="#212121"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btn_finish_session"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Back to Home"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="24dp" />
    </LinearLayout>

</LinearLayout>
